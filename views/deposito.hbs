<main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Registrar depósito</h1>
      <p class="subtitulo">Ingresar fondos a una cuenta activa.</p>
    </section>

    <section class="seccion">
      <form class="formulario">
        <div class="grid-formularios">
          <div class="campo">
            <label for="cuenta-deposito">Cuenta (cliente o Número)</label>
            <input id="cuenta-deposito" type="text" placeholder="CR__ ____ ____ ____ ____ o nombre de cliente">
          </div>
          <div class="campo">
            <label for="descripcion-deposito">Descripción</label>
            <input id="descripcion-deposito" type="text" placeholder="Motivo del depósito">
          </div>
          <div class="campo">
            <label for="monto-deposito">Monto del depósito</label>
            <input id="monto-deposito" type="number" step="0.01" min="0.01" placeholder="Debe ser mayor a cero">
          </div>
          <div class="campo">
            <label for="moneda-deposito">Tipo de moneda</label>
            <select id="moneda-deposito">
              <option>CRC</option>
              <option>USD</option>
            </select>
          </div>
        </div>
        <div class="botones">
          <button class="btn" id="btn-registrar-deposito" type="button">Registrar depósito</button>
          <button class="btn btn-secundario" type="reset">Limpiar</button>
          <a class="btn btn-secundario" href="/transacciones">Volver</a>
        </div>
        <p class="subtitulo" style="margin-top:1rem;">Solo se permite si cliente y cuenta están activos.</p>
      </form>
    </section>

    <section class="seccion" id="resultado-deposito" style="display:none;">
      <h2 class="titulo-seccion">Resumen del depósito realizado</h2>
      <div class="tabla-center">
        <table class="tabla-resumen">
          <thead>
            <tr>
              <th>Código</th>
              <th>Cuenta (IBAN)</th>
              <th>Descripción</th>
              <th>Fecha</th>
              <th>Monto ingresado</th>
              <th>Monto acreditado</th>
              <th>Saldo final</th>
              <th>Tipo de cambio</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td id="res-codigo"></td>
              <td id="res-iban" class="nowrap"></td>
              <td id="res-descripcion"></td>
              <td id="res-fecha"></td>
              <td id="res-monto-ingresado"></td>
              <td id="res-monto-acreditado"></td>
              <td id="res-saldo-final"></td>
              <td id="res-tipo-cambio"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
  <script src="/javascripts/transacciones-logica.js"></script>

