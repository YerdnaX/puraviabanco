<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Banco Pura Vida | Inicio</title>
  <link rel="stylesheet" href="css/estilos.css">
</head>
<body>
  <header>
    <div class="barra-usuario">
      <img src="imagenes/logos.png" alt="Banco Pura Vida" class="logo-header">
      <img src="imagenes/logos2.png" alt="Banco Pura Vida" class="logo-header">
    </div>
    <nav class="menu-superior">
      <a href="inicio.html">Inicio</a>
      <a href="panel.html">Dashboard</a>
      <a href="clientes.html">Clientes</a>
      <a href="cuentas.html">Cuentas</a>
      <a href="transacciones.html">Transacciones</a>
      <a href="configuracion.html">Configuración</a>
      <a href="contacto.html">Contacto</a>
    </nav>
  </header>

  <main class="contenedor">
    <section class="hero">
      <div class="hero-texto">
        <h1>Administra clientes, cuentas y transacciones desde un solo panel</h1>
        <p>Diseñado para equipos que necesitan manejo bancario.</p>
        <div class="botones">
          <a class="btn" href="panel.html">Ir al dashboard</a>
          <a class="btn btn-secundario" href="clientes.html">Registrar cliente</a>
        </div>
      </div>
      <div class="tarjeta">
        <ul class="lista-simple" style="margin:0; padding:0; list-style:none;">
          <li>Registrar cliente.</li>
          <li>Crear cuentas.</li>
          <li>Registrar transacciones.</li>
        </ul>
      </div>
    </section>

    <section class="seccion">
      <h2 class="titulo-seccion">Indicadores del banco</h2>
      <div class="kpi-grid">
        <div class="kpi">
          <div class="etiqueta">Clientes activos</div>
          <div class="valor">3 482</div>
          <div class="estado estado-libre">+86 este mes</div>
        </div>
        <div class="kpi">
          <div class="etiqueta">Cuentas abiertas</div>
          <div class="valor">5 120</div>
          <div class="estado estado-libre">CRC  USD</div>
        </div>
        <div class="kpi">
          <div class="etiqueta">Transacciones del día</div>
          <div class="valor">842</div>
          <div class="estado estado-libre">Depósitos, retiros y comisiones</div>
        </div>
      </div>
    </section>
    <section class="seccion">
      <div class="banner">
        <div>
          <h2>Control total con datos claros</h2>
          <p>Consulta listas de clientes, cuentas y movimientos. Cada pantalla está pensada para operar rápido y con trazabilidad total.</p>
          <div class="botones">
            <a class="btn btn-secundario" href="contacto.html">Solicitar soporte</a>
          </div>
        </div>
        <div>
          <div class="tarjeta">
            <h3>Vista rápida</h3>
            <p><strong>Cliente:</strong> 1-0456-1234  Activo</p>
            <p><strong>Cuenta:</strong> CR05 0123 0000 4567 8901  CRC</p>
            <p><strong>Última transacción:</strong> Depósito · ₡ 250 000 · 18/03/2026</p>
            <p><strong>Saldo final:</strong> ₡ 1 540 000</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <img src="imagenes/logos2.png" alt="Banco Pura Vida" class="logo-header" style="display: block; margin: 0 auto;">
  <footer> 2026 Banco Pura Vida. Wil Mora :D</footer>
</body>
</html>












