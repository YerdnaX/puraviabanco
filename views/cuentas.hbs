<main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Administración de cuentas bancarias</h1>
      <div class="kpi-grid">
        <div class="kpi">
          <div class="etiqueta">Cuentas activas</div>
          <div class="valor">{{cuentasActivas}}</div>
          <div class="estado estado-libre">Con estado Activa</div>
        </div>
        <div class="kpi">
          <div class="etiqueta">Cuentas inactivas</div>
          <div class="valor">{{cuentasInactivas}}</div>
          <div class="estado estado-reservada">Sin operaciones permitidas</div>
        </div>
        <div class="kpi">
          <div class="etiqueta">Última alta</div>
          <div class="valor">{{ultimaAltaFecha}}</div>
          <div class="estado estado-libre">{{ultimaAltaHora}}</div>
        </div>
      </div>
    </section>

    <section class="seccion">
      <h2 class="titulo-seccion">Cuentas registradas</h2>
      <div class="tabla-center">
      <table class="tabla-resumen">
        <thead>
        <tr>
          <th>Número de cuenta (IBAN)</th>
          <th>Alias</th>
          <th>Moneda</th>
          <th>Saldo actual</th>
          <th>Cliente</th>
          <th>Creada</th>
          <th>Estado</th>
          <th>Transacciones</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        {{#each cuentasLista}}
        <tr>
          <td>{{this.iban}}</td>
          <td>{{this.aliasCuenta}}</td>
          <td>{{this.moneda}}</td>
          <td>{{this.saldoActual}}</td>
          <td>{{this.clienteNombre}}</td>
          <td>{{this.creadaTexto}}</td>
          <td><span class="estado {{this.estadoClase}}">{{this.estado}}</span></td>
          <td>
            <a class="btn btn-secundario btn-icon" href="/cuentas/transaccionescuenta?iban={{this.ibanUrl}}" aria-label="Ver transacciones">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="11" cy="11" r="6"></circle>
                <path d="M16 16l4 4"></path>
              </svg>
            </a>
          </td>
          <td>
            <form method="post" action="/api/cuentas/eliminar" style="display:inline;" data-eliminar="cuenta">
              <input type="hidden" name="iban" value="{{this.ibanRaw}}">
              <button class="btn btn-secundario btn-icon" type="submit">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4 7h16"></path>
                  <path d="M9 4h6"></path>
                  <path d="M10 10v7"></path>
                  <path d="M14 10v7"></path>
                  <rect x="5" y="7" width="14" height="13" rx="2"></rect>
                </svg>
              </button>
            </form>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    </div>
  </section>

    <section class="seccion">
      <h2 class="titulo-seccion">Crear o modificar cuenta</h2>
      <form class="formulario">
        <div class="grid-formularios">
          <div class="campo">
            <label for="iban">Número de cuenta (IBAN)</label>
            <input id="iban" type="text" placeholder="CR__ ____ ____ ____ ____"
              pattern="^[A-Z]{2}\\d{2}[A-Z0-9]{4}\\d{7}([A-Z0-9]-){0,16}$"
              title="Formato: país + 2 dígitos + hasta 30 alfanuméricos">
          </div>
          <div class="campo">
            <label for="alias">Alias de la cuenta</label>
            <input id="alias" type="text" placeholder="Ej. Ahorros casa">
          </div>
          <div class="campo">
            <label for="moneda">Tipo de moneda</label>
            <select id="moneda">
              <option>CRC</option>
              <option>USD</option>
            </select>
          </div>
          <div class="campo">
            <label for="saldo">Saldo actual</label>
            <input id="saldo" type="number" step="0.01" placeholder="0.00">
          </div>
          <div class="campo">
            <label for="cliente">Cliente propietario</label>
            <input id="cliente" type="text" placeholder="Nombre o identificador">
          </div>
          <div class="campo">
            <label for="estado-cuenta">Estado de la cuenta</label>
            <select id="estado-cuenta">
              <option>Activa</option>
              <option>Inactiva</option>
            </select>
          </div>
        </div>

        <div class="botones">
          <button class="btn" id="btn-guardar-actualizar-cuenta" type="button">Guardar / Actualizar</button>
          <button class="btn btn-secundario" type="reset">Limpiar</button>
        </div>
        </p>
      </form>
    </section>
  </main>
  <script src="/javascripts/cuentas-logica.js"></script>

