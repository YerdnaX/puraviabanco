    <section class="seccion">
      <h2 class="titulo-seccion">Crear o modificar cliente</h2>
      <form class="formulario">
        <div class="grid-formularios">
          <div class="campo">
            <label for="id-cliente">Identificador (cédula, extranjero o pasaporte)</label>
            <input id="id-cliente" type="text" placeholder="Ej. 1-0456-1234 / P-99332211">
          </div>
          <div class="campo">
            <label for="nombre">Nombre completo</label>
            <input id="nombre" type="text" placeholder="Nombre y apellidos">
          </div>
          <div class="campo">
            <label for="correo">Correo electrónico</label>
            <input id="correo" type="email" placeholder="correo@ejemplo.com">
          </div>
          <div class="campo">
            <label for="telefono">Número de teléfono</label>
            <input id="telefono" type="tel" placeholder="8888-8888">
          </div>
          <div class="campo">
            <label for="fecha-nacimiento">Fecha de nacimiento</label>
            <input id="fecha-nacimiento" type="date">
          </div>
        </div>

        <div class="grid-formularios">
          <div class="campo">
            <label for="direccion">Dirección</label>
            <textarea id="direccion" placeholder="Provincia, cantón, distrito"></textarea>
          </div>
          <div class="campo">
            <label for="ocupacion">Ocupación</label>
            <input id="ocupacion" type="text" placeholder="Profesión u oficio">
          </div>
          <div class="campo">
            <label for="fecha-creacion">Fecha de creación</label>
            <input id="fecha-creacion" type="date">
          </div>
          <div class="campo">
            <label for="estado">Estado del cliente</label>
            <select id="estado">
              <option>Activo</option>
              <option>Inactivo</option>
            </select>
          </div>
        </div>

        <div class="botones">
          <button class="btn" type="button">Guardar / Actualizar</button>
          <button class="btn btn-secundario" type="reset">Limpiar</button>
        </div>
      </form>
    </section>
  </main>

