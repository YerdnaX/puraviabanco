<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Banco Pura Vida | Contacto</title>
  <link rel="stylesheet" href="css/estilos.css">
</head>
<body>
  <header>
    <div class="barra-usuario">
      <img src="imagenes/logos.png" alt="Banco Pura Vida" class="logo-header">
      <img src="imagenes/logos2.png" alt="Banco Pura Vida" class="logo-header">
    </div>
    <nav class="menu-superior">
      <a href="inicio.html">Inicio</a>
      <a href="panel.html">Dashboard</a>
      <a href="clientes.html">Clientes</a>
      <a href="cuentas.html">Cuentas</a>
      <a href="transacciones.html">Transacciones</a>
      <a href="configuracion.html">Configuración</a>
      <a href="contacto.html">Contacto</a>
    </nav>
  </header>

  <main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Contacto y soporte</h1>
      <p class="subtitulo">Escríbenos para soporte funcional, incidencias de operación o ajustes de parámetros.</p>

      <div class="contacto-info">
        <div><strong>Oficina central:</strong> Avenida 2, San José, Costa Rica.</div>
        <div><strong>Teléfono:</strong> +506 4000 1000</div>
        <div><strong>Correo soporte:</strong> soporte@bancopuravia.cr</div>
        <div><strong>Horario:</strong> Lunes a viernes  8:00 a.m. - 6:00 p.m.</div>
      </div>

      <form class="formulario">
        <div class="grid-formularios">
          <div class="campo">
            <label for="nombre">Nombre</label>
            <input id="nombre" type="text" placeholder="Nombre">
          </div>
          <div class="campo">
            <label for="correo">Correo</label>
            <input id="correo" type="email" placeholder="Correo institucional">
          </div>
          <div class="campo">
            <label for="telefono">Teléfono</label>
            <input id="telefono" type="tel" placeholder="Ej. 8888-8888">
          </div>
          <div class="campo">
            <label for="asunto">Asunto</label>
            <input id="asunto" type="text" placeholder="Incidencia, solicitud o cambio">
          </div>
        </div>
        <div class="campo">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" placeholder="Describe la solicitud o incidente con detalle"></textarea>
        </div>
        <div class="botones">
          <button class="btn" type="button">Enviar</button>
          <button class="btn btn-secundario" type="reset">Limpiar</button>
        </div>
      </form>
    </section>
  </main>
  <img src="imagenes/logos2.png" alt="Banco Pura Vida" class="logo-header" style="display:block; margin:0 auto;">
  <footer> 2026 Banco Pura Vida. Wil Mora :D</footer>
</body>
</html>












