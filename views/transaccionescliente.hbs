<main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Perfil del cliente</h1>
      <p class="subtitulo">Consulta transacciones, solicitudes de prestamo y desglose de cuotas del cliente seleccionado.</p>

      <div class="kpi-grid" style="margin-bottom:1.2rem;">
        <div class="kpi">
          <div class="etiqueta">Cliente</div>
          <div class="valor">{{clienteNombre}}</div>
          <div class="estado estado-libre">ID: {{clienteId}}</div>
        </div>
        <div class="kpi">
          <div class="etiqueta">Cuentas activas</div>
          <div class="valor">{{cuentasActivas}}</div>
          <div class="estado estado-libre">{{monedasActivasTexto}}</div>
        </div>
        <div class="kpi">
          <div class="etiqueta">Saldo agregado</div>
          <div class="valor">{{saldoAgregadoTexto}}</div>
          <div class="estado estado-reservada">Incluye conversion de USD</div>
        </div>
      </div>

      <h2 class="titulo-seccion" style="margin-bottom:0.8rem;">Solicitudes de prestamo</h2>
      <table class="tabla-resumen" style="margin-bottom:1.2rem;">
        <thead>
          <tr>
            <th>Numero solicitud</th>
            <th>Fecha</th>
            <th>Monto solicitado</th>
            <th>Plazo</th>
            <th>Cuota mensual</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          {{#each solicitudesPrestamo}}
          <tr>
            <td>{{this.numeroSolicitud}}</td>
            <td>{{this.fechaSolicitud}}</td>
            <td>{{this.montoPrestamo}}</td>
            <td>{{this.plazoMeses}}</td>
            <td>{{this.cuotaMensual}}</td>
            <td>{{this.estado}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="6">Este cliente no tiene solicitudes de prestamo registradas.</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <h2 class="titulo-seccion" style="margin-bottom:0.8rem;">Desglose de cuotas</h2>
      <table class="tabla-resumen" style="margin-bottom:1.2rem;">
        <thead>
          <tr>
            <th>Numero solicitud</th>
            <th>Cuota #</th>
            <th>Fecha estimada</th>
            <th>Monto cuota</th>
            <th>Saldo estimado</th>
          </tr>
        </thead>
        <tbody>
          {{#each cuotasPrestamo}}
          <tr>
            <td>{{this.numeroSolicitud}}</td>
            <td>{{this.numeroCuota}}</td>
            <td>{{this.fechaCuota}}</td>
            <td>{{this.montoCuota}}</td>
            <td>{{this.saldoEstimado}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="5">No hay cuotas para mostrar porque no existen solicitudes de prestamo.</td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <h2 class="titulo-seccion" style="margin-bottom:0.8rem;">Transacciones del cliente</h2>
      <table class="tabla-resumen">
        <thead>
          <tr>
            <th>ID</th>
            <th>Fecha</th>
            <th>Tipo</th>
            <th>Descripcion</th>
            <th>Cuenta</th>
            <th>Monto</th>
            <th>Moneda</th>
            <th>Tipo de cambio</th>
            <th>Saldo final</th>
            <th>Referencia</th>
          </tr>
        </thead>
        <tbody>
          {{#each transaccionesCliente}}
          <tr>
            <td>{{this.id}}</td>
            <td>{{this.fecha}}</td>
            <td>{{this.tipo}}</td>
            <td>{{this.descripcion}}</td>
            <td>{{this.cuenta}}</td>
            <td>{{this.monto}}</td>
            <td>{{this.moneda}}</td>
            <td>{{this.tipoCambio}}</td>
            <td>{{this.saldoFinal}}</td>
            <td>{{this.referencia}}</td>
          </tr>
          {{else}}
          <tr>
            <td colspan="10">Este cliente no tiene transacciones registradas.</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      <div class="botones" style="margin-top:1.2rem;">
        <a class="btn btn-secundario" href="/clientes">Volver a clientes</a>
      </div>
    </section>
  </main>
