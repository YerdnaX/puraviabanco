<main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Administrar rangos de comisión</h1>
      <p class="subtitulo">Estos rangos se aplican automáticamente a los retiros según el monto.</p>
    </section>

    <section class="seccion">
      <form class="formulario">
        <div class="tabla-scroll">
          <table class="tabla-resumen tabla-editable-rangos">
            <thead>
              <tr>
                <th>Monto mínimo</th>
                <th>Monto máximo</th>
                <th>Porcentaje</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><input type="number" step="0.01" min="0" value="0" aria-label="Monto mínimo rango 1"></td>
                <td><input type="number" step="0.01" min="0" value="100000" aria-label="Monto máximo rango 1"></td>
                <td><input type="number" step="0.01" min="0" value="1.5" aria-label="Porcentaje rango 1"></td>
                <td>
                  <select aria-label="Estado rango 1">
                    <option selected>Vigente</option>
                    <option>Inactivo</option>
                  </select>
                </td>
              </tr>
              <tr>
                <td><input type="number" step="0.01" min="0" value="100001" aria-label="Monto mínimo rango 2"></td>
                <td><input type="number" step="0.01" min="0" value="500000" aria-label="Monto máximo rango 2"></td>
                <td><input type="number" step="0.01" min="0" value="3" aria-label="Porcentaje rango 2"></td>
                <td>
                  <select aria-label="Estado rango 2">
                    <option selected>Vigente</option>
                    <option>Inactivo</option>
                  </select>
                </td>
              </tr>
              <tr>
                <td><input type="number" step="0.01" min="0" value="500001" aria-label="Monto mínimo rango 3"></td>
                <td><input type="number" step="0.01" min="0" value="2000000" aria-label="Monto máximo rango 3"></td>
                <td><input type="number" step="0.01" min="0" value="4.5" aria-label="Porcentaje rango 3"></td>
                <td>
                  <select aria-label="Estado rango 3">
                    <option selected>Vigente</option>
                    <option>Inactivo</option>
                  </select>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="botones acciones-rangos">
          <button class="btn" type="submit">Guardar</button>
          <button class="btn btn-secundario" type="button">Ultimas Rangos</button>
          <a class="btn btn-secundario" href="/configuracion">Volver</a>
        </div>

        <p class="subtitulo">Los rangos no deben superponerse.</p>
      </form>
    </section>
  </main>

