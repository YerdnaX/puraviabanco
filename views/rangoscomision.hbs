<main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Administrar rangos de comisión</h1>
      <p class="subtitulo">Estos rangos se aplican automáticamente a los retiros según el monto.</p>
    </section>

    <section class="seccion">
      <h2 class="titulo-seccion">Historial de rangos de comisión</h2>
      <table class="tabla-resumen" style="margin-bottom: 1.2rem;">
        <thead>
          <tr>
            <th>ID</th>
            <th>Monto mínimo</th>
            <th>Monto máximo</th>
            <th>Porcentaje</th>
            <th>Fecha de modificación</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody>
          {{#if historialRangos.length}}
          {{#each historialRangos}}
          <tr>
            <td>{{this.id}}</td>
            <td>{{this.montoMinimoTexto}}</td>
            <td>{{this.montoMaximoTexto}}</td>
            <td>{{this.porcentajeTexto}}</td>
            <td>{{this.fechaTexto}}</td>
            <td><span class="estado {{this.estadoClase}}">{{this.estadoTexto}}</span></td>
          </tr>
          {{/each}}
          {{else}}
          <tr>
            <td colspan="6">No hay historial de rangos registrado.</td>
          </tr>
          {{/if}}
        </tbody>
      </table>

      <form class="formulario" id="form-rangos-comision">
        <div class="tabla-scroll">
          <table class="tabla-resumen tabla-editable-rangos">
            <thead>
              <tr>
                <th>Monto mínimo</th>
                <th>Monto máximo</th>
                <th>Porcentaje</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><input type="number" step="1" min="0" value="0" data-campo="minimo" data-rango="1" aria-label="Monto mínimo rango 1"></td>
                <td><input type="number" step="1" min="0" value="100000" data-campo="maximo" data-rango="1" aria-label="Monto máximo rango 1"></td>
                <td><input type="number" step="0.01" min="0" value="1.5" data-campo="porcentaje" data-rango="1" aria-label="Porcentaje rango 1"></td>
              </tr>
              <tr>
                <td><input type="number" step="1" min="0" value="100001" data-campo="minimo" data-rango="2" aria-label="Monto mínimo rango 2"></td>
                <td><input type="number" step="1" min="0" value="500000" data-campo="maximo" data-rango="2" aria-label="Monto máximo rango 2"></td>
                <td><input type="number" step="0.01" min="0" value="3" data-campo="porcentaje" data-rango="2" aria-label="Porcentaje rango 2"></td>
              </tr>
              <tr>
                <td><input type="number" step="1" min="0" value="500001" data-campo="minimo" data-rango="3" aria-label="Monto mínimo rango 3"></td>
                <td><input type="number" step="1" min="0" value="2000000" data-campo="maximo" data-rango="3" aria-label="Monto máximo rango 3"></td>
                <td><input type="number" step="0.01" min="0" value="4.5" data-campo="porcentaje" data-rango="3" aria-label="Porcentaje rango 3"></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="botones acciones-rangos">
          <button class="btn" id="btn-guardar-rangos" type="submit">Guardar</button>
          <button class="btn btn-secundario" id="btn-ultimos-rangos" type="button">Últimos Rangos</button>
          <a class="btn btn-secundario" href="/configuracion">Volver</a>
        </div>

        <p class="subtitulo">Los rangos no deben superponerse.</p>
      </form>
    </section>
  </main>
  <script src="/javascripts/configuracion-logica.js"></script>

