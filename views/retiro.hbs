<main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Registrar retiro</h1>
      <p class="subtitulo">Descuento de fondos con verificación de saldo y cálculo de comisión automática.</p>
    </section>

    <section class="seccion">
      <div class="grid-formularios">
        <form class="formulario">
          <h3>Retiro</h3>
          <div class="campo">
            <label for="cuenta-retiro">Cuenta (cliente o Número)</label>
            <input id="cuenta-retiro" type="text" placeholder="CR__ ____ ____ ____ ____">
          </div>
          <div class="campo">
            <label for="descripcion-retiro">Descripción</label>
            <input id="descripcion-retiro" type="text" placeholder="Motivo del retiro">
          </div>
          <div class="campo">
            <label for="monto-retiro">Monto</label>
            <input id="monto-retiro" type="number" step="0.01" min="0.01" placeholder="Validar saldo suficiente">
          </div>
          <div class="campo">
            <label for="moneda-retiro">Tipo de moneda</label>
            <select id="moneda-retiro">
              <option>CRC</option>
              <option>USD</option>
            </select>
          </div>
          <div class="botones">
            <button class="btn" id="btn-registrar-retiro" type="button">Registrar retiro</button>
            <button class="btn btn-secundario" type="reset">Limpiar</button>
            <a class="btn btn-secundario" href="/transacciones">Volver</a>
          </div>
          <p class="subtitulo">El sistema verifica saldo antes de permitir el retiro.</p>
        </form>

        <div class="factura">
          <h3>Cálculo de comisión</h3>
          <div class="fila-resumen">
            <span>Rango aplicado</span><span id="retiro-rango-aplicado">N/D</span>
          </div>
          <div class="fila-resumen">
            <span>Porcentaje</span><span id="retiro-porcentaje-comision">N/D</span>
          </div>
          <div class="fila-resumen">
            <span>Comisión calculada</span><span id="retiro-comision-calculada">N/D</span>
          </div>
          <div class="fila-resumen">
            <span>Saldo tras retiro</span><span id="retiro-saldo-tras-retiro">N/D</span>
          </div>
          <p>La comisión se registra automáticamente como transacción ligada al retiro.</p>
          <div class="campo">
            <label>Comisión calculada</label>
            <div class="pill" id="retiro-pill-comision">N/D</div>
          </div>
        </div>
      </div>
    </section>

    <section class="seccion" id="resultado-retiro" style="display:none;">
      <h2 class="titulo-seccion">Resumen del retiro realizado</h2>
      <div class="tabla-center">
        <table class="tabla-resumen">
          <thead>
            <tr>
              <th>ID Retiro</th>
              <th>ID Comisión</th>
              <th>Cuenta (IBAN)</th>
              <th>Fecha</th>
              <th>Monto retiro</th>
              <th>Comisión aplicada</th>
              <th>Saldo final</th>
              <th>Tipo de cambio</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td id="res-retiro-id"></td>
              <td id="res-comision-id"></td>
              <td id="res-retiro-iban" class="nowrap"></td>
              <td id="res-retiro-fecha"></td>
              <td id="res-retiro-monto"></td>
              <td id="res-retiro-comision"></td>
              <td id="res-retiro-saldo-final"></td>
              <td id="res-retiro-tipo-cambio"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
  <script src="/javascripts/transacciones-logica.js"></script>

